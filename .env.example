# OpenRouter (https://openrouter.ai) — primary LLM backend
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=openai/gpt-4o-mini
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Optional OpenRouter attribution headers:
# OPENROUTER_HTTP_REFERER=https://your-app.streamlit.app
# OPENROUTER_X_TITLE=EXAI Research Interview

# Set to 1 to run without the API (deterministic mock responses)
EXAI_MOCK_LLM=0

# On Streamlit Cloud, set keys under App settings → Secrets (see README.md).
