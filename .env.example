# OpenRouter (https://openrouter.ai) — основний спосіб викликів LLM
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=openai/gpt-4o-mini
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Опційно для рейтингу в OpenRouter:
# OPENROUTER_HTTP_REFERER=https://your-app.streamlit.app
# OPENROUTER_X_TITLE=EXAI Research Interview

# Set to 1 to run without API (deterministic mock responses)
EXAI_MOCK_LLM=0

# На Streamlit Cloud ключ задають у App settings → Secrets (див. README.md).
